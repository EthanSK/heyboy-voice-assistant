#!/usr/bin/env bash
# heyboy CLI helper
# OpenClaw-inspired UX for install/setup/doctor/run/app flows.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
ENV_TEMPLATE="${PROJECT_ROOT}/.env.example"
ENV_FILE="${PROJECT_ROOT}/.env"
DEFAULT_API_BASE_URL="http://127.0.0.1:3333"

LAUNCH_LABEL="io.github.ethansk.heyboy.voice-assistant"
LAUNCH_DIR="${HOME}/Library/LaunchAgents"
LAUNCH_PLIST="${LAUNCH_DIR}/${LAUNCH_LABEL}.plist"
APP_LOG_DIR="${HOME}/Library/Logs/heyboy-voice-assistant"
APP_STDOUT_LOG="${APP_LOG_DIR}/stdout.log"
APP_STDERR_LOG="${APP_LOG_DIR}/stderr.log"

usage() {
  cat <<'EOF'
heyboy voice assistant CLI

Usage:
  scripts/heyboy install
  scripts/heyboy setup <openclaw|codex|claude|generic> [options]
  scripts/heyboy doctor
  scripts/heyboy run
  scripts/heyboy quickstart <openclaw|codex|claude|generic> [options]

  scripts/heyboy app install
  scripts/heyboy app start
  scripts/heyboy app stop
  scripts/heyboy app status
  scripts/heyboy app uninstall

Setup options:
  --api-key <token>        Set API_KEY (openclaw backend)
  --api-base-url <url>     Set API_BASE_URL (openclaw backend)
  --model <name>           Set MODEL_NAME (default gpt-5.2)
  --thinking <level>       Set THINKING_LEVEL (default low)
  --codex-command <cmd>    Override CODEX_CLI_COMMAND
  --claude-command <cmd>   Override CLAUDE_CLI_COMMAND
  --command <cmd>          Required for generic backend (GENERIC_CLI_COMMAND)

Examples:
  scripts/heyboy quickstart openclaw --api-key "$OPENCLAW_TOKEN"
  scripts/heyboy setup codex
  scripts/heyboy setup claude --claude-command "claude --dangerously-skip-permissions --print"
  scripts/heyboy setup generic --command "ollama run llama3.2"
  scripts/heyboy app install
  scripts/heyboy app start
EOF
}

ensure_env_file() {
  if [ ! -f "$ENV_FILE" ]; then
    cp "$ENV_TEMPLATE" "$ENV_FILE"
    echo "[setup] Created .env from .env.example"
  fi
}

quote_env_value() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"' "$value"
}

upsert_env() {
  local key="$1"
  local raw="$2"
  local value
  value="$(quote_env_value "$raw")"

  python3 - "$ENV_FILE" "$key" "$value" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]

if path.exists():
    lines = path.read_text().splitlines()
else:
    lines = []

needle = f"{key}="
updated = False
for i, line in enumerate(lines):
    if line.startswith(needle):
        lines[i] = f"{key}={value}"
        updated = True
        break

if not updated:
    lines.append(f"{key}={value}")

path.write_text("\n".join(lines) + "\n")
PY
}

load_env_exports() {
  if [ ! -f "$ENV_FILE" ]; then
    return 0
  fi

  eval "$({
    python3 - "$ENV_FILE" <<'PY'
import shlex
import sys
from pathlib import Path

path = Path(sys.argv[1])
if not path.exists():
    raise SystemExit(0)

values = {}
for raw in path.read_text().splitlines():
    line = raw.strip()
    if not line or line.startswith("#"):
        continue
    if "=" not in line:
        continue
    key, value = line.split("=", 1)
    key = key.strip()
    value = value.strip()
    if not key:
        continue

    # Strip matching quotes.
    if len(value) >= 2 and ((value[0] == value[-1]) and value[0] in ('"', "'")):
        value = value[1:-1]

    # Basic unescape for double-quoted values
    value = value.replace("\\\"", '"').replace("\\\\", "\\")
    values[key] = value

for key, value in values.items():
    safe = shlex.quote(value)
    print(f"CFG_{key}={safe}")
PY
  } )"
}

print_detected_tools() {
  for cmd in openclaw codex claude; do
    if command -v "$cmd" >/dev/null 2>&1; then
      echo "  ✅ ${cmd}"
    else
      echo "  ⚪ ${cmd} (not found)"
    fi
  done
}

first_token() {
  python3 - "$1" <<'PY'
import shlex
import sys
parts = shlex.split(sys.argv[1])
print(parts[0] if parts else "")
PY
}

check_command_prefix() {
  local label="$1"
  local prefix="$2"
  local token
  token="$(first_token "$prefix")"

  if [ -z "$token" ]; then
    echo "  ❌ ${label}: command is empty"
    return 1
  fi

  if command -v "$token" >/dev/null 2>&1; then
    echo "  ✅ ${label}: ${prefix}"
    return 0
  fi

  echo "  ❌ ${label}: executable '${token}' not found on PATH"
  return 1
}

probe_codex_cli_auth() {
  local prefix="$1"
  local timeout_s="${2:-25}"

  python3 - "$prefix" "$timeout_s" <<'PY'
import shlex
import subprocess
import sys

prefix = sys.argv[1]
timeout_s = int(sys.argv[2])

args = shlex.split(prefix)
if not args:
    print("  ❌ Codex CLI auth probe: command is empty")
    raise SystemExit(2)

args.append("Reply with exactly: OK")

try:
    completed = subprocess.run(
        args,
        capture_output=True,
        text=True,
        timeout=timeout_s,
        check=False,
    )
except subprocess.TimeoutExpired:
    print(f"  ❌ Codex CLI auth probe timed out after {timeout_s}s")
    raise SystemExit(3)
except Exception as exc:
    print(f"  ❌ Codex CLI auth probe failed to start: {exc}")
    raise SystemExit(4)

if completed.returncode == 0:
    print("  ✅ Codex CLI auth probe")
    raise SystemExit(0)

blob = f"{completed.stderr or ''}\n{completed.stdout or ''}".lower()
auth_indicators = (
    "refresh_token_reused",
    "provided authentication token is expired",
    "token is expired",
    "failed to refresh token",
    "log out and sign in again",
    "sign in again",
    "401 unauthorized",
)
if any(token in blob for token in auth_indicators):
    print("  ❌ Codex CLI auth invalid/expired — run: codex logout && codex login")
    raise SystemExit(10)

snippet_source = (completed.stderr or completed.stdout or "").strip()
snippet = ""
for line in snippet_source.splitlines():
    candidate = line.strip()
    if candidate:
        snippet = candidate
        break

if snippet:
    print(f"  ❌ Codex CLI auth probe failed (exit {completed.returncode}): {snippet[:140]}")
else:
    print(f"  ❌ Codex CLI auth probe failed (exit {completed.returncode})")
raise SystemExit(11)
PY
}

setup_backend() {
  local backend="$1"
  shift || true

  ensure_env_file

  local api_key=""
  local api_base_url="$DEFAULT_API_BASE_URL"
  local model="gpt-5.2"
  local thinking="low"
  local codex_command="codex exec"
  local claude_command="claude --dangerously-skip-permissions --print"
  local generic_command=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --api-key)
        api_key="${2:-}"
        shift 2
        ;;
      --api-base-url)
        api_base_url="${2:-}"
        shift 2
        ;;
      --model)
        model="${2:-}"
        shift 2
        ;;
      --thinking)
        thinking="${2:-}"
        shift 2
        ;;
      --codex-command)
        codex_command="${2:-}"
        shift 2
        ;;
      --claude-command)
        claude_command="${2:-}"
        shift 2
        ;;
      --command)
        generic_command="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  case "$backend" in
    openclaw)
      upsert_env ASSISTANT_BACKEND openclaw_api
      upsert_env API_BASE_URL "$api_base_url"
      upsert_env MODEL_NAME "$model"
      upsert_env THINKING_LEVEL "$thinking"
      if [ -n "$api_key" ]; then
        upsert_env API_KEY "$api_key"
      fi
      echo "[setup] Backend configured: openclaw_api"
      echo "        API_BASE_URL=${api_base_url}"
      echo "        MODEL_NAME=${model}"
      echo "        THINKING_LEVEL=${thinking}"
      ;;

    codex)
      upsert_env ASSISTANT_BACKEND codex_cli
      upsert_env CODEX_CLI_COMMAND "$codex_command"
      echo "[setup] Backend configured: codex_cli"
      echo "        CODEX_CLI_COMMAND=${codex_command}"
      ;;

    claude)
      upsert_env ASSISTANT_BACKEND claude_cli
      upsert_env CLAUDE_CLI_COMMAND "$claude_command"
      echo "[setup] Backend configured: claude_cli"
      echo "        CLAUDE_CLI_COMMAND=${claude_command}"
      ;;

    generic)
      if [ -z "$generic_command" ]; then
        echo "ERROR: generic backend requires --command \"<executable ...>\""
        exit 1
      fi
      upsert_env ASSISTANT_BACKEND generic_cli
      upsert_env GENERIC_CLI_COMMAND "$generic_command"
      echo "[setup] Backend configured: generic_cli"
      echo "        GENERIC_CLI_COMMAND=${generic_command}"
      ;;

    *)
      echo "ERROR: backend must be one of openclaw|codex|claude|generic"
      exit 1
      ;;
  esac

  echo "[setup] .env updated: ${ENV_FILE}"
}

doctor() {
  local failures=0
  local warnings=0

  echo "heyboy doctor"
  echo "============="

  if command -v python3 >/dev/null 2>&1; then
    echo "  ✅ python3: $(python3 --version)"
  else
    echo "  ❌ python3 not found"
    failures=$((failures + 1))
  fi

  if [ -x "${PROJECT_ROOT}/.venv/bin/python" ]; then
    echo "  ✅ virtualenv: ${PROJECT_ROOT}/.venv"
  else
    echo "  ⚪ virtualenv missing (.venv) — run scripts/heyboy install"
    warnings=$((warnings + 1))
  fi

  if [ -f "$ENV_FILE" ]; then
    echo "  ✅ env file: ${ENV_FILE}"
    load_env_exports
  else
    echo "  ❌ env file missing: ${ENV_FILE}"
    failures=$((failures + 1))
  fi

  local vosk_path="${CFG_VOSK_MODEL_PATH:-models/vosk-model-small-en-us}"
  if [ -d "${PROJECT_ROOT}/${vosk_path}" ] || [ -d "$vosk_path" ]; then
    echo "  ✅ vosk model path found: ${vosk_path}"
  else
    echo "  ⚪ vosk model path missing: ${vosk_path} (run scripts/heyboy install)"
    warnings=$((warnings + 1))
  fi

  local backend="${CFG_ASSISTANT_BACKEND:-openclaw_api}"
  echo "  ℹ️  backend: ${backend}"

  case "$backend" in
    openclaw_api)
      if [ -n "${CFG_API_BASE_URL:-}" ]; then
        echo "  ✅ API_BASE_URL: ${CFG_API_BASE_URL}"
      else
        echo "  ❌ API_BASE_URL missing"
        failures=$((failures + 1))
      fi

      if [ -n "${CFG_API_KEY:-}" ] && [ "${CFG_API_KEY}" != "replace-with-your-token" ]; then
        echo "  ✅ API_KEY is configured"
      else
        echo "  ❌ API_KEY missing/placeholder"
        failures=$((failures + 1))
      fi

      echo "  ✅ MODEL_NAME: ${CFG_MODEL_NAME:-gpt-5.2}"
      echo "  ✅ THINKING_LEVEL: ${CFG_THINKING_LEVEL:-low}"
      ;;

    codex_cli)
      local codex_prefix="${CFG_CODEX_CLI_COMMAND:-codex exec}"
      if check_command_prefix "Codex CLI" "$codex_prefix"; then
        probe_codex_cli_auth "$codex_prefix" || failures=$((failures + 1))
      else
        failures=$((failures + 1))
      fi
      ;;

    claude_cli)
      check_command_prefix "Claude CLI" "${CFG_CLAUDE_CLI_COMMAND:-claude --dangerously-skip-permissions --print}" || failures=$((failures + 1))
      ;;

    generic_cli)
      check_command_prefix "Generic CLI" "${CFG_GENERIC_CLI_COMMAND:-}" || failures=$((failures + 1))
      ;;

    *)
      echo "  ❌ ASSISTANT_BACKEND invalid: ${backend}"
      failures=$((failures + 1))
      ;;
  esac

  local py_bin="python3"
  if [ -x "${PROJECT_ROOT}/.venv/bin/python" ]; then
    py_bin="${PROJECT_ROOT}/.venv/bin/python"
  fi

  if "$py_bin" - <<'PY' >/dev/null 2>&1
import importlib
for mod in ["vosk", "sounddevice", "soundfile", "numpy", "pyttsx3", "requests", "dotenv"]:
    importlib.import_module(mod)
PY
  then
    echo "  ✅ Python deps import check"
  else
    echo "  ⚪ Python deps incomplete — run scripts/heyboy install"
    warnings=$((warnings + 1))
  fi

  echo ""
  echo "Detected optional backend tools:"
  print_detected_tools

  echo ""
  if [ "$failures" -gt 0 ]; then
    echo "doctor result: FAIL (${failures} failure(s), ${warnings} warning(s))"
    return 1
  fi

  if [ "$warnings" -gt 0 ]; then
    echo "doctor result: OK with warnings (${warnings})"
  else
    echo "doctor result: OK"
  fi
}

quickstart() {
  local backend="${1:-}"
  if [ -z "$backend" ]; then
    echo "ERROR: quickstart requires a backend (openclaw|codex|claude|generic)"
    exit 1
  fi
  shift || true

  "${SCRIPT_DIR}/install_part1_deps.sh"
  setup_backend "$backend" "$@"
  doctor
}

write_launch_agent_plist() {
  mkdir -p "$LAUNCH_DIR" "$APP_LOG_DIR"

  cat > "$LAUNCH_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>${LAUNCH_LABEL}</string>

    <key>ProgramArguments</key>
    <array>
      <string>${SCRIPT_DIR}/run_voice_assistant.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>${PROJECT_ROOT}</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>${APP_STDOUT_LOG}</string>

    <key>StandardErrorPath</key>
    <string>${APP_STDERR_LOG}</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
  </dict>
</plist>
EOF

  echo "[app] LaunchAgent installed: ${LAUNCH_PLIST}"
}

app_install() {
  ensure_env_file
  write_launch_agent_plist
  echo "[app] Next: scripts/heyboy app start"
}

app_start() {
  if [ ! -f "$LAUNCH_PLIST" ]; then
    app_install
  fi

  launchctl bootout "gui/${UID}/${LAUNCH_LABEL}" >/dev/null 2>&1 || true

  if launchctl bootstrap "gui/${UID}" "$LAUNCH_PLIST"; then
    launchctl enable "gui/${UID}/${LAUNCH_LABEL}" >/dev/null 2>&1 || true
    launchctl kickstart -k "gui/${UID}/${LAUNCH_LABEL}" >/dev/null 2>&1 || true
    echo "[app] Started: ${LAUNCH_LABEL}"
    echo "[app] Logs: ${APP_STDOUT_LOG}"
  else
    echo "[app] Failed to bootstrap LaunchAgent in gui/${UID}."
    echo "[app] Likely blocker: no active GUI login session for this user."
    return 1
  fi
}

app_stop() {
  if launchctl bootout "gui/${UID}/${LAUNCH_LABEL}" >/dev/null 2>&1; then
    echo "[app] Stopped: ${LAUNCH_LABEL}"
  else
    echo "[app] LaunchAgent not running in gui/${UID} (or no GUI domain)."
  fi
}

app_status() {
  if launchctl print "gui/${UID}/${LAUNCH_LABEL}" >/dev/null 2>&1; then
    launchctl print "gui/${UID}/${LAUNCH_LABEL}" | sed -n '1,40p'
    echo "[app] Logs: ${APP_STDOUT_LOG}"
  else
    echo "[app] Not loaded in gui/${UID}."
    if [ -f "$LAUNCH_PLIST" ]; then
      echo "[app] LaunchAgent file exists: ${LAUNCH_PLIST}"
    fi
    return 1
  fi
}

app_uninstall() {
  app_stop || true
  rm -f "$LAUNCH_PLIST"
  echo "[app] Removed: ${LAUNCH_PLIST}"
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  install)
    "${SCRIPT_DIR}/install_part1_deps.sh" "$@"
    ;;

  setup)
    backend="${1:-}"
    if [ -z "$backend" ]; then
      echo "ERROR: setup requires backend argument"
      usage
      exit 1
    fi
    shift || true
    setup_backend "$backend" "$@"
    ;;

  doctor)
    doctor
    ;;

  run)
    "${SCRIPT_DIR}/run_voice_assistant.sh" "$@"
    ;;

  quickstart)
    quickstart "$@"
    ;;

  app)
    sub="${1:-status}"
    shift || true
    case "$sub" in
      install) app_install ;;
      start) app_start ;;
      stop) app_stop ;;
      status) app_status ;;
      uninstall) app_uninstall ;;
      *)
        echo "Unknown app subcommand: $sub"
        echo "Use: scripts/heyboy app <install|start|stop|status|uninstall>"
        exit 1
        ;;
    esac
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "Unknown command: $cmd"
    usage
    exit 1
    ;;
esac
