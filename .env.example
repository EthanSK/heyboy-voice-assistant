# heyboy-voice-assistant configuration
# Copy to .env and edit values for your environment.

# -----------------------------------------------------------------------------
# Assistant routing backend
#   openclaw_api  -> OpenAI-compatible HTTP endpoint (recommended for OpenClaw)
#   codex_cli     -> local Codex CLI command
#   claude_cli    -> local Claude Code CLI command
#   generic_cli   -> any local CLI command template
# -----------------------------------------------------------------------------
ASSISTANT_BACKEND=openclaw_api

# -----------------------------------------------------------------------------
# Wake/listen behavior
# -----------------------------------------------------------------------------
WAKE_PHRASE="hey boy"
LISTEN_ACK="Hi, I'm listening."
LISTEN_SECONDS=7
SAMPLE_RATE=16000
# Wake detector audio chunk size (seconds). Higher = lower CPU, slightly higher wake latency.
AUDIO_CHUNK_DURATION_S=0.20
VOSK_MODEL_PATH=models/vosk-model-small-en-us

# Multi-turn session controls
# MULTI_TURN_ENABLED=1 keeps a short follow-up window after each response so
# you can continue speaking without saying the wake phrase again.
MULTI_TURN_ENABLED=1
MULTI_TURN_MAX_TURNS=3
FOLLOWUP_LISTEN_SECONDS=7
NO_SPEECH_RETRY_LIMIT=1
WAKE_ONLY_RETRY_LIMIT=1
FOLLOWUP_PROMPT=""
FOLLOWUP_NO_SPEECH_PROMPT="Still here. What next?"
FOLLOWUP_TIMEOUT_PROMPT="Okay, pausing now."
SESSION_END_PROMPT=""
NO_SPEECH_PROMPT="I didn't catch that."
WAKE_ONLY_PROMPT="I heard the wake phrase, but not your request."
EMPTY_BACKEND_REPLY="Sorry, I don't have a response right now."
MAX_TRANSCRIPT_CHARS=1200

# Speech-to-text backend
#   vosk_local -> local Vosk STT
#   deepgram   -> Deepgram API STT (recommended quality)
STT_BACKEND=vosk_local
DEEPGRAM_API_KEY=replace-with-your-deepgram-token
DEEPGRAM_MODEL=nova-3
DEEPGRAM_TIMEOUT=20

# -----------------------------------------------------------------------------
# OpenAI-compatible API settings (OpenClaw/OpenRouter/OpenAI/self-hosted)
# -----------------------------------------------------------------------------
API_BASE_URL=http://127.0.0.1:3333
API_KEY=replace-with-your-token
MODEL_NAME=gpt-5.2
THINKING_LEVEL=low
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=400
LLM_TIMEOUT=30

# Optional prompt override
SYSTEM_PROMPT="You are a concise, helpful voice assistant. Keep responses short and clear."

# -----------------------------------------------------------------------------
# CLI backend settings
# -----------------------------------------------------------------------------
# Codex wrapper applies these defaults unless your CODEX_CLI_COMMAND already
# includes explicit model/config flags.
CODEX_MODEL_NAME=gpt-5.2
CODEX_REASONING_LEVEL=none
CODEX_CLI_COMMAND="codex exec"
CLAUDE_CLI_COMMAND="claude --dangerously-skip-permissions --print"
# For generic_cli mode, include the executable and any fixed flags only.
# The user prompt is appended as the final argument.
GENERIC_CLI_COMMAND=""
CLI_TIMEOUT=120

# -----------------------------------------------------------------------------
# Barge-in controls
# -----------------------------------------------------------------------------
BARGE_IN_THRESHOLD=0.03
BARGE_IN_HOLD_MS=220
BARGE_IN_GRACE_MS=350

# TTS/wake echo protections (prevents jagged duplicate prompts)
TTS_DUPLICATE_WINDOW_MS=1200
WAKE_SUPPRESS_AFTER_TTS_MS=900

# Speech endpointing (latency reduction)
EARLY_ENDPOINTING_ENABLED=1
ENDPOINT_SPEECH_THRESHOLD=0.015
ENDPOINT_MIN_SPEECH_MS=220
ENDPOINT_TRAILING_SILENCE_MS=680

# -----------------------------------------------------------------------------
# Conversation memory and diagnostics
# -----------------------------------------------------------------------------
HISTORY_MAX_MESSAGES=20
HISTORY_MAX_CHARS=12000

# Audio retry/recovery for transient device errors
AUDIO_RETRY_ATTEMPTS=3
AUDIO_RETRY_BACKOFF_S=0.35
AUDIO_RETRY_BACKOFF_MAX_S=2.0

LOG_LEVEL=INFO
DEBUG_SAVE_AUDIO=0
DEBUG_AUDIO_DIR=tmp/audio
